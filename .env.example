# .env.example
# Backend environment example

# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/apes

# Redis (local default; replace with Upstash URL in production)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev_fallback_jwt_secret_key_12345
JWT_EXPIRES_IN=7d

# Groq (API key for LLM)
GROQ_API_KEY=

# Cloudinary (credentials)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail (for email delivery)
GMAIL_USER=
GMAIL_APP_PASS=

# WhatsApp session path (for whatsapp-web.js)
WHATSAPP_SESSION_PATH=./whatsapp-session

# Face service URL
FACE_SERVICE_URL=http://localhost:8001
